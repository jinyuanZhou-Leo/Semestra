# input:  [Deployment environments, OAuth provider configuration, database URL, auth-session runtime settings]
# output: [Template environment variables for local/prod backend setup]
# pos:    [Environment configuration template for backend runtime, JWT signing, and auth-cookie transport]
#
# ⚠️ When this file is updated:
#    1. Update these header comments
#    2. Update the INDEX.md of the folder this file belongs to
#
# Template for environment variables
# Copy this to .env for local development and fill in actual values

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Database Configuration
# Development: Use SQLite
# Production: Use Postgres (Cloud SQL/Supabase/Neon/etc.)
DATABASE_URL=sqlite:///./semestra.db

# Frontend URL
FRONTEND_URL=http://localhost:5173

# JWT signing key
# Production must set a long random value here.
JWT_SECRET_KEY=replace-me-with-a-long-random-secret

# Auth cookie settings
AUTH_COOKIE_NAME=semestra_session
# Keep `lax` for same-site frontend/backend deployments. Use `none` only when you intentionally deploy cross-site and also enable HTTPS.
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=

# Environment type: development or production
ENVIRONMENT=development
